# ============================================
# INGRESOTARUKA - Variables de Entorno
# ============================================

# --- Base de datos PostgreSQL ---
DATABASE_URL="postgresql://USUARIO:CONTRASEÑA@HOST:5432/taruka_gym?schema=public"

# --- JWT ---
JWT_SECRET="cambiar-por-un-secreto-largo-y-seguro"

# --- Puerto del servidor backend ---
PORT=4000

# --- URL del frontend (para CORS) ---
CLIENT_URL="http://localhost:3000"

# --- Frontend (Next.js) ---
# Estas se configuran en el panel de Railway/Vercel
NEXT_PUBLIC_API_URL="https://ingresotaruka-production.up.railway.app/api"
NEXT_PUBLIC_SOCKET_URL="https://ingresotaruka-production.up.railway.app"
NEXT_PUBLIC_UPLOADS_URL="https://ingresotaruka-production.up.railway.app"
